# Copie para .env e ajuste (não commite .env)
# Desenvolvimento local (compose.yaml) — SSL não é necessário
PORT=80

# Produção: docker compose --profile production up -d && ./scripts/init-ssl.sh
DOMAIN=55lab.com.br
CERTBOT_EMAIL=seu-email@empresa.com.br

# Backend API (docker compose up mysql api queue)
MYSQL_DATABASE=55lab
MYSQL_USER=55lab
MYSQL_PASSWORD=55lab_secret
MYSQL_ROOT_PASSWORD=root_secret
# Gere com: docker compose exec api php artisan key:generate --show
APP_KEY=

EDITAL_AI_PROVIDER=mock
OPENAI_API_KEY=

# Helpdesk — integração com sistemas externos (55conta etc.)
EXTERNAL_HELPDESK_API_KEY=55lab_helpdesk_api_key
EXTERNAL_HELPDESK_WEBHOOK_URL=
EXTERNAL_HELPDESK_WEBHOOK_TIMEOUT=15
EXTERNAL_HELPDESK_WEBHOOK_RETRIES=3
EXTERNAL_HELPDESK_ATTACHMENT_MAX_BYTES=10485760
